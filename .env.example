# Davis Taiwan APP — Environment Variables
# Copy to .env for local development
# Set these in Netlify dashboard for production

# Anthropic API (for AI analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (existing Davis project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Admin auth (replace with random 64-char string!)
DAVIS_TOKEN_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# Optional: Google Maps API key (for groomer map)
VITE_GOOGLE_MAPS_KEY=
